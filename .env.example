PROCUREWATCH_ENV=local
PROCUREWATCH_DATA_DIR=data

# Servicios locales opcionales para fases posteriores.
# Agent1 puede usar estas variables para persistir el MVP en PostgreSQL cuando se ejecute
# con --write-postgres.
PROCUREWATCH_POSTGRES_DSN=postgresql://procurewatch:procurewatch@localhost:5432/procurewatch
PROCUREWATCH_NEO4J_URI=bolt://localhost:7687
PROCUREWATCH_NEO4J_USER=neo4j
PROCUREWATCH_NEO4J_PASSWORD=procurewatch123
PROCUREWATCH_QDRANT_URL=http://localhost:6333
PROCUREWATCH_OLLAMA_BASE_URL=http://localhost:11434
PROCUREWATCH_OLLAMA_MODEL=qwen3:8b
PROCUREWATCH_OLLAMA_EMBEDDING_MODEL=bge-m3
